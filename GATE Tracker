// ─── DASHBOARD ────────────────────────────────────────────────────────────────
function getCurrentFocus(){
  const m=TODAY.getMonth(), y=TODAY.getFullYear();
  if(y===2027) return TODAY_FOCUS[10];
  return TODAY_FOCUS.find(f=>f.month===m)||TODAY_FOCUS[0];
}

function renderDashboard(){
  const f=getCurrentFocus();
  document.getElementById('dash-focus-text').textContent=f.text;
  document.getElementById('dash-focus-sub').textContent=f.sub;

  const studied=state.studiedDays||[];
  const streak=calcStreak(studied);
  document.getElementById('streak-num').textContent=streak;
  document.getElementById('streak-sub').textContent=
    streak>0?studied.length+' total days studied':'Start today!';
  document.getElementById('st-days').textContent=studied.length;

  const avg=GATE_SUBJECTS.reduce((a,s)=>{
    const d=state.subjects[s.name]||{};return a+(d.pct||0);
  },0)/GATE_SUBJECTS.length;
  document.getElementById('st-subj').textContent=Math.round(avg)+'%';
  document.getElementById('st-errors').textContent=(state.errors||[]).length;
  document.getElementById('st-mocks').textContent=(state.mocks||[]).length;

  renderWeekGrid();

  document.getElementById('overall-progress-bars').innerHTML=GATE_SUBJECTS.map(s=>{
    const d=state.subjects[s.name]||{};
    const pct=d.pct||0;
    const col=pct>=80?'var(--teal)':pct>=40?'var(--amber)':'var(--blue)';
    const ovl=s.overlap?'<span class="overlap-tag">UNI OVERLAP</span>':'';
    return `<div style="margin-bottom:12px">
      <div style="display:flex;justify-content:space-between;margin-bottom:4px;align-items:center">
        <span style="font-size:12px;font-weight:500">${s.name}${ovl}</span>
        <span style="font-size:11px;color:var(--text2);font-family:'Space Mono',monospace">${pct}%</span>
      </div>
      <div class="pbar-wrap"><div class="pbar" style="width:${pct}%;background:${col}"></div></div>
    </div>`;
  }).join('');

  document.getElementById('phase-cards').innerHTML=PHASES.map(ph=>{
    const pct=state.phaseProgress[ph.key]||0;
    const col=ph.color==='b-blue'?'var(--blue)':ph.color==='b-amber'?'var(--amber)':ph.color==='b-teal'?'var(--teal)':'var(--purple)';
    return `<div class="phase-card">
      <div class="phase-hdr">
        <div class="phase-title">${ph.name}</div>
        <span class="badge ${ph.color}">${pct}%</span>
      </div>
      <div class="phase-dates">${ph.dates}</div>
      <div class="pbar-wrap"><div class="pbar" style="width:${pct}%;background:${col}"></div></div>
      <div class="phase-btns">
        ${[0,25,50,75,100].map(v=>`<button class="btn-sm" onclick="setPhase('${ph.key}',${v})">${v}%</button>`).join('')}
      </div>
    </div>`;
  }).join('');
}

function renderWeekGrid(){
  const studied=state.studiedDays||[];
  const weekStart=new Date(TODAY);
  weekStart.setDate(TODAY.getDate()-TODAY.getDay());
  const days=['S','M','T','W','T','F','S'];
  let html=days.map(d=>`<div class="wday">${d}</div>`).join('');
  for(let i=0;i<7;i++){
    const d=new Date(weekStart); d.setDate(weekStart.getDate()+i);
    const k=d.toISOString().slice(0,10);
    const isToday=k===todayKey;
    const done=studied.includes(k);
    const checks=state.dailyChecks[k]||{};
    const doneCount=Object.values(checks).filter(Boolean).length;
    const cls=done?'done':doneCount>0?'partial':'';
    html+=`<div class="wdot ${cls} ${isToday?'today':''}" title="${k}"></div>`;
  }
  document.getElementById('week-grid').innerHTML=html;
}

function calcStreak(days){
  if(!days||!days.length) return 0;
  const sorted=[...days].sort().reverse();
  let streak=0,cur=new Date(TODAY);
  for(const d of sorted){
    const dd=new Date(d);
    const diff=Math.round((cur-dd)/(1000*60*60*24));
    if(diff<=1){streak++;cur=dd;}else break;
  }
  return streak;
}

function markTodayDone(){
  const days=state.studiedDays||[];
  if(!days.includes(todayKey)) state.studiedDays=[...days,todayKey];
  saveState();renderDashboard();
}

function setPhase(key,val){
