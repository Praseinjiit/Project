      <div style="font-family:'Space Mono',monospace;font-size:10px;font-weight:700;color:var(--teal-light);letter-spacing:.08em;text-transform:uppercase;margin-bottom:6px">University today</div>
      ${uniClasses.map(c=>`<div style="display:flex;align-items:center;gap:8px;margin-bottom:4px">
        <span style="font-size:11px;color:var(--text3);font-family:'Space Mono',monospace;min-width:48px">${c.time}</span>
        <span class="badge ${c.type==='lab'?'b-teal':'b-blue'}">${c.code}</span>
        ${c.note?`<span style="font-size:10px;color:var(--text3)">${c.note}</span>`:''}
      </div>`).join('')}
    </div>`;
  } else {
    uniEl.innerHTML='';
  }

  document.getElementById('checklist').innerHTML=sessions.map(s=>{
    const done=checks[s.id]||false;
    const typeClass={'gate':'ci-gate','uni':'ci-uni','both':'ci-both'}[s.type]||'ci-misc';
    const typeLabel={'gate':'GATE','uni':'UNI','both':'GATE + UNI'}[s.type]||'';
    return `<div class="check-item" onclick="toggleCheck('${s.id}')">
      <div class="chk ${done?'done':''}"></div>
      <div class="ci-content">
        <div class="ci-label ${done?'done':''}">${s.label}</div>
        ${s.sub?`<div class="ci-sub">${s.sub}</div>`:''}
        <span class="ci-type ${typeClass}">${typeLabel}</span>
      </div>
      <div class="ci-time">${s.time}</div>
    </div>`;
  }).join('');

  const notes=state.dailyNotes||{};
  document.getElementById('daily-notes').value=notes[todayKey]||'';
}

function toggleCheck(id){
  if(!state.dailyChecks[todayKey]) state.dailyChecks[todayKey]={};
  state.dailyChecks[todayKey][id]=!state.dailyChecks[todayKey][id];
  const dayOfWeek=TODAY.getDay();
  const sessions=getDailySessions(dayOfWeek);
  const all=Object.values(state.dailyChecks[todayKey]).filter(Boolean).length;
  if(all===sessions.length){
    const days=state.studiedDays||[];
    if(!days.includes(todayKey)) state.studiedDays=[...days,todayKey];
  }
  saveState();renderDaily();renderDashboard();
}

function saveNotes(){
  if(!state.dailyNotes) state.dailyNotes={};
  state.dailyNotes[todayKey]=document.getElementById('daily-notes').value;
  saveState();
}

// ─── GATE SUBJECTS ────────────────────────────────────────────────────────────
function renderSubjects(){
  document.getElementById('subj-grid').innerHTML=GATE_SUBJECTS.map(s=>{
    const d=state.subjects[s.name]||{pct:0};
    const pct=d.pct||0;
    const col=pct>=80?'var(--teal)':pct>=40?'var(--amber)':'var(--blue)';
    const isActive=activeSubj===s.name;
    return `<div class="sj ${isActive?'active':''}" onclick="selectSubj('${s.name}')">
      <div class="sj-name">${s.name}${s.overlap?'<span class="overlap-tag" style="margin-left:4px;font-size:8px">UNI</span>':''}</div>
      <div class="sj-marks">${s.marks} marks · ${s.month}</div>
      <div class="pbar-wrap"><div class="pbar" style="width:${pct}%;background:${col}"></div></div>
      <div class="sj-pct" style="color:${col}">${pct}%</div>
    </div>`;
  }).join('');

  if(activeSubj){
    const s=GATE_SUBJECTS.find(x=>x.name===activeSubj);
    const d=state.subjects[activeSubj]||{pct:0,status:'not_started',notes:''};
    document.getElementById('subj-detail-wrapper').innerHTML=`
      <div class="subj-detail">
        <div class="card-hdr">
          <div class="card-title">${activeSubj}</div>
          <span class="badge ${s.color}">${s.marks} marks</span>
        </div>
        ${s.overlap?`<div style="font-size:11px;color:var(--purple-light);background:var(--purple-dim);padding:6px 10px;border-radius:6px;margin-bottom:10px">University overlap — use your uni classes to reinforce this subject!</div>`:''}
        <div class="sec" style="margin-top:0">Completion %</div>
        <input type="range" min="0" max="100" step="5" value="${d.pct||0}" oninput="updateSubjPct(this.value)" style="margin-bottom:6px">
        <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--text2);margin-bottom:12px">
          <span>0%</span>
          <span id="sd-pct-label" style="font-weight:700;color:var(--text);font-family:'Space Mono',monospace">${d.pct||0}%</span>
          <span>100%</span>
        </div>
        <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px">
          <button class="btn-sm" onclick="setSubjStatus('not_started')">Not started</button>
          <button class="btn-sm" onclick="setSubjStatus('in_progress')">In progress</button>
          <button class="btn-sm" onclick="setSubjStatus('revision')">Revision</button>
          <button class="btn-sm" onclick="setSubjStatus('done')">Done</button>
        </div>
        <div class="sec">Notes / weak areas</div>
        <textarea id="sd-notes" placeholder="Topic notes, weak areas, resources..." oninput="saveSubjNotes()" style="min-height:55px">${d.notes||''}</textarea>
      </div>`;
  } else {
    document.getElementById('subj-detail-wrapper').innerHTML='';
  }
}

function selectSubj(name){
  activeSubj=activeSubj===name?null:name;
  renderSubjects();
  if(activeSubj) setTimeout(()=>document.getElementById('subj-detail-wrapper').scrollIntoView({behavior:'smooth',block:'nearest'}),50);
}

function updateSubjPct(val){
  if(!activeSubj) return;
  if(!state.subjects[activeSubj]) state.subjects[activeSubj]={};
  state.subjects[activeSubj].pct=parseInt(val);
  const lbl=document.getElementById('sd-pct-label');
  if(lbl) lbl.textContent=val+'%';
  saveState();renderDashboard();
}

function setSubjStatus(status){
  if(!activeSubj) return;
  if(!state.subjects[activeSubj]) state.subjects[activeSubj]={};
  state.subjects[activeSubj].status=status;
  if(status==='done') state.subjects[activeSubj].pct=100;
  if(status==='not_started') state.subjects[activeSubj].pct=0;
  saveState();renderSubjects();renderDashboard();
}

function saveSubjNotes(){
  if(!activeSubj) return;
  if(!state.subjects[activeSubj]) state.subjects[activeSubj]={};
  state.subjects[activeSubj].notes=document.getElementById('sd-notes').value;
  saveState();
}

// ─── UNIVERSITY SUBJECTS ──────────────────────────────────────────────────────
function renderUniSubjects(){
  document.getElementById('uni-subj-grid').innerHTML=UNI_SUBJECTS.map(s=>{
    const d=state.uniSubjects[s.code]||{pct:0};
    const pct=d.pct||0;
    const col=pct>=80?'var(--teal)':pct>=40?'var(--amber)':'var(--blue)';
    const isActive=activeUniSubj===s.code;
    return `<div class="uj ${isActive?'active':''}" onclick="selectUniSubj('${s.code}')">
      <div class="uj-code">${s.code}</div>
      <div class="uj-name">${s.name}</div>
      <div class="uj-teacher">Prof: ${s.teacher} ${s.overlap?'· <span style="color:var(--purple-light)">GATE: '+s.overlap+'</span>':''}</div>
      <div class="pbar-wrap"><div class="pbar" style="width:${pct}%;background:${col}"></div></div>
      <div class="uj-pct" style="color:${col}">${pct}%</div>
    </div>`;
  }).join('');

  if(activeUniSubj){
    const s=UNI_SUBJECTS.find(x=>x.code===activeUniSubj);
    const d=state.uniSubjects[activeUniSubj]||{pct:0,notes:''};
    document.getElementById('uni-detail-wrapper').innerHTML=`
      <div class="subj-detail" style="border-color:rgba(16,185,129,0.4)">
        <div class="card-hdr">
          <div class="card-title">${s.code} — ${s.name}</div>
          <span class="badge ${s.color}">Prof: ${s.teacher}</span>
        </div>
        ${s.overlap?`<div style="font-size:11px;color:var(--purple-light);background:var(--purple-dim);padding:6px 10px;border-radius:6px;margin-bottom:10px">GATE overlap: ${s.overlap}</div>`:''}
        <div class="sec" style="margin-top:0">Understanding / preparation %</div>
        <input type="range" min="0" max="100" step="5" value="${d.pct||0}" oninput="updateUniPct(this.value)" style="margin-bottom:6px">
        <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--text2);margin-bottom:12px">
          <span>0%</span>
          <span id="ud-pct-label" style="font-weight:700;color:var(--text);font-family:'Space Mono',monospace">${d.pct||0}%</span>
          <span>100%</span>
        </div>
        <div class="sec">Notes / assignment status</div>
        <textarea id="ud-notes" placeholder="Assignment status, viva topics, weak areas..." oninput="saveUniNotes()" style="min-height:55px">${d.notes||''}</textarea>
      </div>`;
  } else {
    document.getElementById('uni-detail-wrapper').innerHTML='';
  }
}

function selectUniSubj(code){
  activeUniSubj=activeUniSubj===code?null:code;
  renderUniSubjects();
  if(activeUniSubj) setTimeout(()=>document.getElementById('uni-detail-wrapper').scrollIntoView({behavior:'smooth',block:'nearest'}),50);
}

function updateUniPct(val){
  if(!activeUniSubj) return;
  if(!state.uniSubjects[activeUniSubj]) state.uniSubjects[activeUniSubj]={};
  state.uniSubjects[activeUniSubj].pct=parseInt(val);
  const lbl=document.getElementById('ud-pct-label');
  if(lbl) lbl.textContent=val+'%';
  saveState();
}

function saveUniNotes(){
  if(!activeUniSubj) return;
  if(!state.uniSubjects[activeUniSubj]) state.uniSubjects[activeUniSubj]={};
  state.uniSubjects[activeUniSubj].notes=document.getElementById('ud-notes').value;
  saveState();
}

function renderSubjectCodes(){
  const el=document.getElementById('subj-code-list');
  if(!el) return;
  el.innerHTML=`<div class="card"><div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
    ${SUBJ_LABS.map(s=>`<div style="display:flex;justify-content:space-between;align-items:center;padding:5px 0;border-bottom:1px solid var(--border)">
      <span style="font-family:'Space Mono',monospace;font-size:11px;font-weight:700;color:var(--blue-light)">${s.code}</span>
      <span style="font-size:11px;color:var(--text2)">${s.lab}</span>
    </div>`).join('')}
  </div></div>`;
}

// ─── ERRORS ───────────────────────────────────────────────────────────────────
function addError(){
  const subj=document.getElementById('err-subj').value;
  const type=document.getElementById('err-type').value;
  const topic=document.getElementById('err-topic').value.trim();
  const note=document.getElementById('err-note').value.trim();
  if(!subj||!type||!topic){alert('Please fill subject, error type, and topic!');return;}
  if(!state.errors) state.errors=[];
  state.errors.unshift({id:Date.now(),subj,type,topic,note,date:todayKey});
  document.getElementById('err-subj').value='';
  document.getElementById('err-type').value='';
  document.getElementById('err-topic').value='';
  document.getElementById('err-note').value='';
  saveState();renderErrors();renderDashboard();
}

function deleteError(id){
  state.errors=(state.errors||[]).filter(e=>e.id!==id);
  saveState();renderErrors();renderDashboard();
}

function renderErrors(){
  const el=state.errors||[];
  document.getElementById('err-count-lbl').textContent=`Error log (${el.length})`;
  const list=document.getElementById('err-list');
  if(!el.length){list.innerHTML='<div class="empty"><strong>No errors logged yet</strong>Log your first mistake to start improving!</div>';return;}
  const tc={'Conceptual':'b-blue','Calculation':'b-amber','Silly mistake':'b-purple','Time management':'b-teal'};
  list.innerHTML=el.map(e=>`<div class="err-item">
    <div class="err-hdr">
      <span class="err-subj">${e.subj}</span>
      <span class="badge ${tc[e.type]||'b-gray'}">${e.type}</span>
      <span class="err-date">${e.date}</span>
      <button class="del-btn" onclick="deleteError(${e.id})">remove</button>
    </div>
    <div style="font-size:13px;font-weight:500;margin-bottom:${e.note?'4px':'0'}">${e.topic}</div>
    ${e.note?`<div class="err-note">${e.note}</div>`:''}
  </div>`).join('');
}

// ─── MOCKS ────────────────────────────────────────────────────────────────────
function addMock(){
  const date=document.getElementById('mock-date').value||todayKey;
  const score=parseInt(document.getElementById('mock-score').value);
  const series=document.getElementById('mock-series').value;
  const notes=document.getElementById('mock-notes').value.trim();
  if(isNaN(score)||score<0||score>100){alert('Enter a valid score between 0 and 100');return;}
  if(!state.mocks) state.mocks=[];
  state.mocks.unshift({id:Date.now(),date,score,series,notes});
  document.getElementById('mock-score').value='';
  document.getElementById('mock-notes').value='';
  saveState();renderMocks();renderDashboard();
}

function deleteMock(id){
  state.mocks=(state.mocks||[]).filter(m=>m.id!==id);
  saveState();renderMocks();renderDashboard();
}

function renderMocks(){
  const ml=state.mocks||[];
  const sum=document.getElementById('mock-summary');
  const wrap=document.getElementById('mock-list-wrap');
  if(!ml.length){sum.style.display='none';wrap.style.display='none';return;}
  sum.style.display='block';wrap.style.display='block';
  const scores=ml.map(m=>m.score);
  const avg=scores.reduce((a,b)=>a+b,0)/scores.length;
  const best=Math.max(...scores);
  const last3=scores.slice(0,3);
  const l3avg=last3.reduce((a,b)=>a+b,0)/last3.length;
  const pct=Math.min(100,Math.round(avg/85*100));
  document.getElementById('mock-avg').textContent=Math.round(avg);
  document.getElementById('mock-best').textContent=best;
  document.getElementById('mock-count2').textContent=ml.length;
  document.getElementById('mock-trend').textContent=Math.round(l3avg);
  document.getElementById('mock-target-bar').style.width=pct+'%';
  document.getElementById('mock-pct-lbl').textContent=pct+'%';
  document.getElementById('mock-list').innerHTML=ml.map(m=>{
    const cls=m.score>=80?'s-high':m.score>=60?'s-mid':'s-low';
    return `<div class="mock-row">
      <div style="flex:1">
        <div style="font-size:13px;font-weight:500">${m.series}</div>
        <div style="font-size:11px;color:var(--text2);margin-top:2px">${m.date}${m.notes?' · '+m.notes.slice(0,55)+(m.notes.length>55?'...':''):''}</div>
      </div>
      <span class="score-pill ${cls}">${m.score}/100</span>
      <button class="del-btn" onclick="deleteMock(${m.id})">remove</button>
    </div>`;
  }).join('');
}

// ─── INIT ─────────────────────────────────────────────────────────────────────
loadState();
</script>
