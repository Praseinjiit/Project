<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GATE 2027 ECE — AIR 1 Tracker</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0a0e1a;--bg2:#111827;--bg3:#1a2235;
  --border:rgba(255,255,255,0.08);--border2:rgba(255,255,255,0.15);
  --text:#f0f4ff;--text2:#8a9bb8;--text3:#4a5568;
  --blue:#3b82f6;--blue-light:#93c5fd;--blue-dim:rgba(59,130,246,0.15);
  --teal:#10b981;--teal-light:#6ee7b7;--teal-dim:rgba(16,185,129,0.15);
  --amber:#f59e0b;--amber-light:#fcd34d;--amber-dim:rgba(245,158,11,0.15);
  --purple:#8b5cf6;--purple-light:#c4b5fd;--purple-dim:rgba(139,92,246,0.15);
  --coral:#f43f5e;--coral-dim:rgba(244,63,94,0.15);
  --green:#22c55e;--radius:12px;--radius-sm:8px;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;font-size:14px;line-height:1.5}

.app-header{background:var(--bg2);border-bottom:1px solid var(--border);padding:12px 20px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
.app-logo{font-family:'Space Mono',monospace;font-size:13px;font-weight:700;color:var(--blue-light);letter-spacing:.05em}
.app-logo span{color:var(--text2);font-weight:400}
.app-date{font-size:11px;color:var(--text2);font-family:'Space Mono',monospace}

.nav{display:flex;background:var(--bg2);border-bottom:1px solid var(--border);padding:0 20px;overflow-x:auto;-webkit-overflow-scrolling:touch}
.nav::-webkit-scrollbar{display:none}
.ntab{padding:10px 14px;font-size:12px;font-weight:500;cursor:pointer;border-bottom:2px solid transparent;color:var(--text2);white-space:nowrap;transition:color .2s,border-color .2s;letter-spacing:.02em}
.ntab:hover{color:var(--text)}
.ntab.on{color:var(--blue-light);border-bottom-color:var(--blue)}

.page{display:none;padding:16px 20px 80px;max-width:700px;margin:0 auto}
.page.on{display:block;animation:fadeIn .25s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}

.sec{font-family:'Space Mono',monospace;font-size:10px;font-weight:700;color:var(--text3);letter-spacing:.1em;text-transform:uppercase;margin-bottom:10px;margin-top:20px}
.sec:first-child{margin-top:0}

.card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px;margin-bottom:10px;transition:border-color .2s}
.card:hover{border-color:var(--border2)}
.card-hdr{display:flex;align-items:center;gap:8px;margin-bottom:10px}
.card-title{font-size:14px;font-weight:500;flex:1}

.stats{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:8px;margin-bottom:16px}
.scard{background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius-sm);padding:12px 10px;text-align:center}
.snum{font-size:20px;font-weight:600;font-family:'Space Mono',monospace}
.slbl{font-size:10px;color:var(--text2);margin-top:3px}

.badge{font-size:10px;font-weight:500;padding:3px 8px;border-radius:4px;white-space:nowrap;font-family:'Space Mono',monospace}
.b-blue{background:var(--blue-dim);color:var(--blue-light)}
.b-teal{background:var(--teal-dim);color:var(--teal-light)}
.b-amber{background:var(--amber-dim);color:var(--amber-light)}
.b-purple{background:var(--purple-dim);color:var(--purple-light)}
.b-coral{background:var(--coral-dim);color:#fda4af}
.b-gray{background:rgba(255,255,255,0.06);color:var(--text2)}

.pbar-wrap{background:rgba(255,255,255,0.06);border-radius:3px;height:4px}
.pbar{height:4px;border-radius:3px;transition:width .5s cubic-bezier(.4,0,.2,1);min-width:0}

.focus-box{background:var(--blue-dim);border:1px solid rgba(59,130,246,0.3);border-radius:var(--radius);padding:14px 16px;margin-bottom:14px}
.focus-label{font-family:'Space Mono',monospace;font-size:10px;color:var(--blue-light);font-weight:700;letter-spacing:.1em;text-transform:uppercase;margin-bottom:4px}
.focus-text{font-size:16px;font-weight:600;color:var(--text);margin-bottom:3px}
.focus-sub{font-size:12px;color:var(--blue-light);opacity:.8}

.streak-box{display:flex;align-items:center;gap:14px;background:var(--amber-dim);border:1px solid rgba(245,158,11,0.25);border-radius:var(--radius);padding:14px 16px;margin-bottom:14px}
.streak-num{font-size:36px;font-weight:700;font-family:'Space Mono',monospace;color:var(--amber-light);line-height:1}
.streak-info{flex:1}
.streak-title{font-size:14px;font-weight:600}
.streak-sub{font-size:11px;color:var(--text2);margin-top:2px}

.week-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:5px;margin-bottom:16px}
.wday{text-align:center;font-size:10px;color:var(--text3);padding-bottom:3px;font-family:'Space Mono',monospace}
.wdot{width:100%;aspect-ratio:1;border-radius:5px;background:rgba(255,255,255,0.05);border:1px solid transparent;transition:background .2s}
.wdot.done{background:var(--teal)}
.wdot.partial{background:var(--amber);opacity:.6}
.wdot.today{border-color:var(--blue)}

/* TIMETABLE */
.tt-grid{display:grid;grid-template-columns:60px repeat(9,1fr);gap:1px;background:var(--border);border-radius:var(--radius-sm);overflow:hidden;font-size:10px;margin-bottom:12px}
.tt-cell{background:var(--bg2);padding:5px 4px;min-height:32px;display:flex;align-items:center;justify-content:center;text-align:center;font-family:'Space Mono',monospace;font-size:9px;color:var(--text2);line-height:1.3}
.tt-hdr{background:var(--bg3);color:var(--text3);font-weight:700;font-size:8px;letter-spacing:.05em}
.tt-day{background:var(--bg3);color:var(--text2);font-weight:700;font-size:9px}
.tt-subj{color:var(--blue-light);font-weight:700;font-size:9px}
.tt-lab{color:var(--teal-light);font-weight:700;font-size:9px}
.tt-oe{color:var(--amber-light);font-size:9px}
.tt-empty{color:var(--text3)}

/* DAILY CHECKLIST */
.check-item{display:flex;align-items:flex-start;gap:12px;padding:11px 0;border-bottom:1px solid var(--border);cursor:pointer;transition:opacity .15s}
.check-item:last-child{border-bottom:none}
.check-item:hover{opacity:.85}
.chk{width:20px;height:20px;border-radius:6px;border:1.5px solid var(--border2);flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:background .15s,border-color .15s;margin-top:1px}
.chk.done{background:var(--teal);border-color:var(--teal)}
.chk.done::after{content:'';display:block;width:5px;height:9px;border:2px solid #fff;border-top:none;border-left:none;transform:rotate(45deg);margin-top:-2px}
.ci-content{flex:1}
.ci-label{font-size:13px;transition:color .15s}
.ci-label.done{color:var(--text2);text-decoration:line-through}
.ci-sub{font-size:10px;color:var(--text3);margin-top:2px;font-family:'Space Mono',monospace}
.ci-time{font-size:10px;color:var(--text3);font-family:'Space Mono',monospace;white-space:nowrap;flex-shrink:0;padding-top:2px}
.ci-type{font-size:9px;padding:1px 6px;border-radius:3px;display:inline-block;margin-top:3px}
.ci-gate{background:var(--blue-dim);color:var(--blue-light)}
.ci-uni{background:var(--teal-dim);color:var(--teal-light)}
.ci-both{background:var(--purple-dim);color:var(--purple-light)}
.ci-misc{background:rgba(255,255,255,0.06);color:var(--text3)}

/* SUBJECTS */
.subj-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:8px;margin-bottom:12px}
.sj{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:12px;cursor:pointer;transition:border-color .2s,background .2s}
.sj:hover{background:var(--bg3);border-color:var(--border2)}
.sj.active{border-color:var(--blue)}
.sj-name{font-size:12px;font-weight:600;margin-bottom:2px}
.sj-marks{font-size:10px;color:var(--text2);margin-bottom:8px}
.sj-pct{font-size:13px;font-weight:700;text-align:right;margin-top:5px;font-family:'Space Mono',monospace}

.subj-detail{background:var(--bg2);border:1px solid var(--blue);border-radius:var(--radius);padding:16px;margin-bottom:12px}

/* UNI SUBJECTS */
.uni-subj-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:8px}
.uj{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:12px;cursor:pointer;transition:border-color .2s}
.uj:hover{border-color:var(--border2)}
.uj.active{border-color:var(--teal)}
.uj-code{font-family:'Space Mono',monospace;font-size:11px;font-weight:700;color:var(--teal-light);margin-bottom:2px}
.uj-name{font-size:12px;font-weight:500;margin-bottom:2px}
.uj-teacher{font-size:10px;color:var(--text3);margin-bottom:8px}
.uj-pct{font-size:13px;font-weight:700;text-align:right;font-family:'Space Mono',monospace}

/* ERROR LOG */
.err-item{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:12px;margin-bottom:8px;transition:border-color .2s}
.err-item:hover{border-color:var(--border2)}
.err-hdr{display:flex;align-items:center;gap:8px;margin-bottom:5px;flex-wrap:wrap}
.err-subj{font-size:12px;font-weight:600}
.err-note{font-size:12px;color:var(--text2);margin-top:4px;line-height:1.5}
.err-date{font-size:10px;color:var(--text3);margin-left:auto;font-family:'Space Mono',monospace}

/* MOCKS */
.mock-row{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid var(--border)}
.mock-row:last-child{border-bottom:none}
.score-pill{font-size:12px;font-weight:700;padding:3px 10px;border-radius:20px;font-family:'Space Mono',monospace}
.s-high{background:var(--teal-dim);color:var(--teal-light)}
.s-mid{background:var(--amber-dim);color:var(--amber-light)}
.s-low{background:var(--coral-dim);color:#fda4af}

/* PHASE CARDS */
.phase-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px;margin-bottom:10px;transition:border-color .2s}
.phase-card:hover{border-color:var(--border2)}
.phase-hdr{display:flex;align-items:center;gap:8px;margin-bottom:6px}
.phase-title{font-size:14px;font-weight:600;flex:1}
.phase-dates{font-size:11px;color:var(--text2);margin-bottom:8px;font-family:'Space Mono',monospace}
.phase-btns{display:flex;gap:5px;margin-top:10px;flex-wrap:wrap}

/* BUTTONS */
.btn-primary{padding:10px 20px;border-radius:var(--radius-sm);font-size:13px;font-weight:600;background:var(--blue);color:#fff;border:none;cursor:pointer;transition:opacity .15s,transform .1s;font-family:'DM Sans',sans-serif}
.btn-primary:hover{opacity:.85}
.btn-primary:active{transform:scale(0.98)}
.btn-sm{padding:5px 10px;border-radius:6px;font-size:11px;font-weight:500;background:rgba(255,255,255,0.06);color:var(--text2);border:1px solid var(--border);cursor:pointer;transition:background .15s,color .15s;font-family:'DM Sans',sans-serif}
.btn-sm:hover{background:rgba(255,255,255,0.12);color:var(--text)}
.del-btn{font-size:10px;color:var(--coral);cursor:pointer;background:none;border:none;padding:2px 6px;border-radius:4px;transition:background .15s;font-family:'DM Sans',sans-serif}
.del-btn:hover{background:var(--coral-dim)}
.mark-done-btn{padding:8px 14px;border-radius:var(--radius-sm);font-size:12px;font-weight:600;background:var(--teal-dim);color:var(--teal-light);border:1px solid rgba(16,185,129,0.3);cursor:pointer;white-space:nowrap;transition:background .15s;font-family:'DM Sans',sans-serif}
.mark-done-btn:hover{background:rgba(16,185,129,0.25)}

/* FORMS */
input,select,textarea{background:var(--bg3);color:var(--text);border:1px solid var(--border);border-radius:var(--radius-sm);padding:9px 12px;font-size:13px;font-family:'DM Sans',sans-serif;width:100%;transition:border-color .2s;outline:none}
input:focus,select:focus,textarea:focus{border-color:var(--blue)}
input::placeholder,textarea::placeholder{color:var(--text3)}
textarea{resize:vertical;min-height:60px}
select option{background:var(--bg2)}
.form-row{display:flex;gap:8px;margin-bottom:8px}
.form-row>*{flex:1;min-width:0}

.empty{text-align:center;padding:30px 20px;color:var(--text3);font-size:13px}
.empty strong{display:block;font-size:14px;color:var(--text2);margin-bottom:5px}

::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}

@media(max-width:480px){.stats{grid-template-columns:repeat(2,minmax(0,1fr))}.page{padding:12px 14px 80px}.tt-grid{font-size:8px}}

/* OVERLAP HIGHLIGHT */
.overlap-tag{font-size:9px;background:rgba(139,92,246,0.2);color:var(--purple-light);padding:1px 5px;border-radius:3px;font-family:'Space Mono',monospace;margin-left:4px}
</style>
</head>
<body>

<div class="app-header">
  <div class="app-logo">GATE 2027 <span>/ VLSI-IV / AIR 1</span></div>
  <div class="app-date" id="header-date"></div>
</div>

<div class="nav">
  <div class="ntab on" onclick="nav('dashboard',this)">Dashboard</div>
  <div class="ntab" onclick="nav('daily',this)">Today</div>
  <div class="ntab" onclick="nav('timetable',this)">Timetable</div>
  <div class="ntab" onclick="nav('subjects',this)">GATE subjects</div>
  <div class="ntab" onclick="nav('university',this)">University</div>
  <div class="ntab" onclick="nav('errors',this)">Error log</div>
  <div class="ntab" onclick="nav('mocks',this)">Mock scores</div>
</div>

<!-- DASHBOARD -->
<div class="page on" id="pg-dashboard">
  <div class="sec" style="margin-top:16px">Today's focus</div>
  <div class="focus-box">
    <div class="focus-label">Current priority</div>
    <div class="focus-text" id="dash-focus-text">Loading...</div>
    <div class="focus-sub" id="dash-focus-sub"></div>
  </div>

  <div class="streak-box">
    <div class="streak-num" id="streak-num">0</div>
    <div class="streak-info">
      <div class="streak-title">Day streak</div>
      <div class="streak-sub" id="streak-sub">Start today!</div>
    </div>
    <button class="mark-done-btn" onclick="markTodayDone()">Mark today done</button>
  </div>

  <div class="sec">This week</div>
  <div class="week-grid" id="week-grid"></div>

  <div class="stats">
    <div class="scard"><div class="snum" style="color:var(--blue-light)" id="st-days">0</div><div class="slbl">Days studied</div></div>
    <div class="scard"><div class="snum" style="color:var(--teal-light)" id="st-subj">0%</div><div class="slbl">Avg GATE %</div></div>
    <div class="scard"><div class="snum" style="color:var(--coral)" id="st-errors">0</div><div class="slbl">Errors logged</div></div>
    <div class="scard"><div class="snum" style="color:var(--amber-light)" id="st-mocks">0</div><div class="slbl">Mocks taken</div></div>
  </div>

  <div class="sec">GATE subject progress</div>
  <div class="card"><div id="overall-progress-bars"></div></div>

  <div class="sec">Phase progress</div>
  <div id="phase-cards"></div>
</div>

<!-- TODAY -->
<div class="page" id="pg-daily">
  <div class="sec" style="margin-top:16px" id="daily-date-label"></div>
  <div id="uni-classes-today" style="margin-bottom:10px"></div>
  <div class="card">
    <div class="card-hdr">
      <div class="card-title">Daily sessions</div>
      <span class="badge b-teal" id="daily-done-count">0/9 done</span>
    </div>
    <div id="checklist"></div>
  </div>
  <div class="sec">Today's notes</div>
  <div class="card">
    <textarea id="daily-notes" placeholder="Breakthroughs, struggles, things to revisit..." style="border:none;background:transparent;padding:0;width:100%;min-height:70px" oninput="saveNotes()"></textarea>
    <div style="font-size:10px;color:var(--text3);margin-top:6px;font-family:'Space Mono',monospace">AUTO-SAVED</div>
  </div>
</div>

<!-- TIMETABLE -->
<div class="page" id="pg-timetable">
  <div class="sec" style="margin-top:16px">VLSI-IV weekly timetable (W.E.F. March 2026)</div>
  <div style="overflow-x:auto;margin-bottom:12px">
    <div class="tt-grid" style="min-width:600px">
      <!-- HEADER ROW -->
      <div class="tt-cell tt-hdr">Day</div>
      <div class="tt-cell tt-hdr">09-10</div>
      <div class="tt-cell tt-hdr">10-11</div>
      <div class="tt-cell tt-hdr">11-12</div>
      <div class="tt-cell tt-hdr">12-01</div>
      <div class="tt-cell tt-hdr">01-02</div>
      <div class="tt-cell tt-hdr">02-03</div>
      <div class="tt-cell tt-hdr">03-04</div>
      <div class="tt-cell tt-hdr">04-05</div>
      <div class="tt-cell tt-hdr">05-06</div>
      <!-- MON -->
      <div class="tt-cell tt-day">Mon</div>
      <div class="tt-cell tt-oe">OE</div>
      <div class="tt-cell tt-subj">MDM</div>
      <div class="tt-cell tt-empty">—</div>
      <div class="tt-cell tt-empty">—</div>
      <div class="tt-cell" style="font-size:8px;color:var(--text2)">SS[PPI](101)/<br>NT[SVK](106)</div>
      <div class="tt-cell tt-lab">AC(A)[AAP]/<br>DC(B)[SJG]</div>
      <div class="tt-cell tt-lab">SDV(A)[RRJ]/<br>PCB(B)[PPM]</div>
      <div class="tt-cell tt-lab">DSDV(B)[PPM]/<br>ADC(A)[SSM]</div>
      <div class="tt-cell tt-empty">—</div>
      <!-- TUE -->
      <div class="tt-cell tt-day">Tue</div>
      <div class="tt-cell tt-subj">MDM</div>
      <div class="tt-cell tt-subj">EDC[PPK]</div>
      <div class="tt-cell tt-subj">MP[KSK]</div>
      <div class="tt-cell tt-subj">SDV[RRJ]</div>
      <div class="tt-cell tt-subj">PIPR[RKB]</div>
      <div class="tt-cell tt-lab">EDC(A)[PPK]/<br>MP(B)[SSS]</div>
      <div class="tt-cell tt-lab">AC(B)[AAP]/<br>DC(C)[SJG]</div>
      <div class="tt-cell tt-empty">—</div>
      <div class="tt-cell tt-empty">—</div>
      <!-- WED -->
      <div class="tt-cell tt-day">Wed</div>
      <div class="tt-cell tt-oe">OE</div>
      <div class="tt-cell tt-subj">CoI[MTRK]</div>
      <div class="tt-cell tt-subj">MP[KSK]</div>
      <div class="tt-cell tt-subj">EDC[PPK]</div>
      <div class="tt-cell tt-subj">LDBA[MTRK]</div>
      <div class="tt-cell tt-subj">PIPR[RKB]</div>
      <div class="tt-cell tt-lab">AC(E)[AAP]/<br>DC(F)[SJG]</div>
      <div class="tt-cell tt-lab">PCB(A)[PPM]</div>
      <div class="tt-cell tt-lab">DSDV(A)[PPM]/<br>ADC(B)[SSM]</div>
      <!-- THU -->
      <div class="tt-cell tt-day">Thu</div>
      <div class="tt-cell tt-oe">OE</div>
      <div class="tt-cell tt-subj">CoI[MTRK]</div>
      <div class="tt-cell tt-subj">MIL[SPG]</div>
      <div class="tt-cell tt-subj">EDC[PPK]</div>
      <div class="tt-cell tt-subj">SDV[RRJ]</div>
      <div class="tt-cell tt-lab">AC(C)[SSS]/<br>DC(A)[SJG]</div>
      <div class="tt-cell tt-lab">SDV(B)[RRJ]/<br>MP(A)[KSK]</div>
      <div class="tt-cell tt-empty">—</div>
      <div class="tt-cell tt-empty">—</div>
      <!-- FRI -->
      <div class="tt-cell tt-day">Fri</div>
      <div class="tt-cell tt-oe">OE</div>
      <div class="tt-cell tt-subj">MIL[SPG]</div>
      <div class="tt-cell tt-subj">SDV[RRJ]</div>
      <div class="tt-cell tt-empty">—</div>
      <div class="tt-cell tt-empty">—</div>
      <div class="tt-cell tt-lab">AC(F)[AAP]/<br>DC(G)[SJG]</div>
      <div class="tt-cell tt-lab">EDC(B)[PPK]/<br>PCB(A)[PPM]</div>
      <div class="tt-cell tt-empty">—</div>
      <div class="tt-cell tt-empty">—</div>
    </div>
  </div>

  <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:16px;font-size:11px">
    <span style="display:flex;align-items:center;gap:4px"><span style="width:10px;height:10px;background:var(--blue-dim);border:1px solid var(--blue);border-radius:2px;display:inline-block"></span>Theory lecture</span>
    <span style="display:flex;align-items:center;gap:4px"><span style="width:10px;height:10px;background:var(--teal-dim);border:1px solid var(--teal);border-radius:2px;display:inline-block"></span>Lab / practical</span>
    <span style="display:flex;align-items:center;gap:4px"><span style="width:10px;height:10px;background:var(--amber-dim);border:1px solid var(--amber);border-radius:2px;display:inline-block"></span>Open elective</span>
  </div>

